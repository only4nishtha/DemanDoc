# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a multi-platform environment, the lock file may not be portable
# Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock contains specific versions that have been locked.
#   Include or exclude this file as preferred by the developer.
# poetry.lock

# pdm
#   Similar to Pipenv and Poetry, pdm.lock contains specific versions that have been locked.
# pdm.lock
#   pdm class names project wealth
.pdm-python.path
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

